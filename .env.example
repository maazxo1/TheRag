# Copy to .env for local overrides, or set as Hugging Face Space secrets

# URL of your running Ollama instance
OLLAMA_URL=http://localhost:11434

# Model names (must be pulled in Ollama)
LLM_MODEL=llama3.2:latest
EMBEDDING_MODEL=nomic-embed-text

# Server port — HF Spaces requires 7860, local default is 8000
PORT=8000
